#!/bin/bash

# --- 🪄 MAGIC DOS2UNIX AUTO-FIX ---
if grep -q $'\r' "$0"; then
    echo -e "\e[33m[*] Fixing Line Endings automatically...\e[0m"
    sed -i 's/\r$//' "$0"
    exec bash "$0" "$@"
fi
# ----------------------------------------------------

# Colors
GREEN="\e[32m"
CYAN="\e[36m"
YELLOW="\e[33m"
MAGENTA="\e[35m"
RED="\e[31m"
RESET="\e[0m"

BASE_DIR="/var/www/html"
OUT_FILE="/tmp/ai_context_dump.txt"

clear
echo -e "${MAGENTA}=====================================================${RESET}"
echo -e "${GREEN} ☢️ AI CONTEXT SPY - ULTIMATE HACKER MODE (V4.0) ☢️ ${RESET}"
echo -e "${MAGENTA}=====================================================${RESET}"

# 1. Get Project List
cd "$BASE_DIR" || exit
shopt -s nullglob
DIRS=(*/)
shopt -u nullglob

if [ ${#DIRS[@]} -eq 0 ]; then 
    echo -e "${RED}[-] No projects found!${RESET}"
    exit 1
fi

PROJ_LIST=()
echo -e "${YELLOW}Available Projects:${RESET}"
echo -e "${BLUE}-----------------------------------------------------${RESET}"
for i in "${!DIRS[@]}"; do
    PROJ_NAME="${DIRS[$i]%/}"
    if [[ "$PROJ_NAME" != *"_baseline_safe"* && "$PROJ_NAME" != "phpmyadmin" ]]; then
        PROJ_LIST+=("$PROJ_NAME")
        echo -e "${GREEN}  $(( ${#PROJ_LIST[@]} ))) 📁 $PROJ_NAME${RESET}"
    fi
done
echo -e "${BLUE}-----------------------------------------------------${RESET}"
echo -e "${RED}  0) ❌ Exit${RESET}"

# 2. Select Project
read -p "Select a Project SL No [0-${#PROJ_LIST[@]}]: " CH
CH=$(echo "$CH" | tr -cd '0-9')

if [[ "$CH" == "0" || -z "$CH" || "$CH" -gt "${#PROJ_LIST[@]}" ]]; then exit 0; fi

SELECTED_PROJ="${PROJ_LIST[$((CH-1))]}"
PROJ_PATH="$BASE_DIR/$SELECTED_PROJ"

# 3. Database Selection
echo -e "\n${CYAN}[*] Deep Scanning Database & Architecture...${RESET}"
DETECTED_DB=$(sudo grep -rhiEo "(DB_NAME|dbname|database|db_database)[\"'\s=>]+[\"'][^\"']+[\"']" "$PROJ_PATH" 2>/dev/null | grep -v "\$" | head -n 1 | grep -oP "['\"][^'\"]+['\"]" | tr -d "'\"")
if [ -z "$DETECTED_DB" ]; then
    DETECTED_DB=$(sudo grep -rhiP 'new\s+mysqli\s*\(' "$PROJ_PATH" 2>/dev/null | head -n 1 | awk -F',' '{print $4}' | tr -d " '\"()")
fi

echo -e "${YELLOW}Detected DB: ${CYAN}${DETECTED_DB:-None}${RESET}"
read -p "Press Enter to use this DB, OR type the exact Database Name manually: " USER_DB
DB_NAME=${USER_DB:-$DETECTED_DB}

echo -e "\n${YELLOW}[*] Extracting Hacker-Level Context for: ${CYAN}$SELECTED_PROJ${RESET}..."

# 4. Generate Context Report
> "$OUT_FILE"

echo "Hello AI, I am building/editing an advanced PHP & MySQL project. Below is the complete server architecture, deep file structure, tech stack, and database schema. Keep this extremely detailed context in mind for all future code generation." >> "$OUT_FILE"
echo "" >> "$OUT_FILE"
echo "=====================================================" >> "$OUT_FILE"
echo " 📁 PROJECT PROFILE: $SELECTED_PROJ " >> "$OUT_FILE"
echo "=====================================================" >> "$OUT_FILE"

# --- [1] SYSTEM & NGINX ---
CONF_FILE=$(sudo grep -rl "root $PROJ_PATH" /etc/nginx/sites-available/ /etc/nginx/sites-enabled/ 2>/dev/null | head -n 1)
DOMAIN=$(sudo awk '/server_name/ {print $0}' "$CONF_FILE" 2>/dev/null | head -n 1 | sed 's/server_name //;s/;//;s/^[ \t]*//')
EXT_LESS=$(sudo grep -q "@php" "$CONF_FILE" 2>/dev/null && echo "YES" || echo "NO")

echo -e "\n[1] ENVIRONMENT & SERVER" >> "$OUT_FILE"
echo "-----------------------------------" >> "$OUT_FILE"
echo "Project Dir : $PROJ_PATH" >> "$OUT_FILE"
echo "PHP Version : $(php -v | head -n 1 | cut -d' ' -f1,2)" >> "$OUT_FILE"
echo "Domain Used : ${DOMAIN:-Localhost}" >> "$OUT_FILE"
echo "Clean URLs  : $EXT_LESS (Extensionless .php via Nginx)" >> "$OUT_FILE"

# --- [2] TECH STACK & LIBRARIES ---
echo -e "\n[2] DETECTED TECH STACK & LIBRARIES" >> "$OUT_FILE"
echo "-----------------------------------" >> "$OUT_FILE"
if [ -f "$PROJ_PATH/composer.json" ]; then echo "  - 📦 PHP Composer Used" >> "$OUT_FILE"; fi
sudo grep -riqm1 "tailwind" "$PROJ_PATH" && echo "  - 🎨 Tailwind CSS Detected" >> "$OUT_FILE"
sudo grep -riqm1 "bootstrap" "$PROJ_PATH" && echo "  - 🎨 Bootstrap Detected" >> "$OUT_FILE"
sudo grep -riqm1 "jquery" "$PROJ_PATH" && echo "  - ⚙️ jQuery Detected" >> "$OUT_FILE"
sudo grep -riqm1 "axios" "$PROJ_PATH" && echo "  - 🌐 Axios (AJAX) Detected" >> "$OUT_FILE"
sudo grep -riqm1 "sweetalert" "$PROJ_PATH" && echo "  - 🔔 SweetAlert Detected" >> "$OUT_FILE"
sudo grep -riqm1 "chart\.js" "$PROJ_PATH" && echo "  - 📊 Chart.js Detected" >> "$OUT_FILE"

# --- [3] ARCHITECTURE & INCLUDES MAP ---
echo -e "\n[3] ARCHITECTURE (Most Included/Required Files)" >> "$OUT_FILE"
echo "-----------------------------------" >> "$OUT_FILE"
echo "AI Info: These are the core files connecting the app together:" >> "$OUT_FILE"
sudo grep -rEho "(include|require)(_once)?\s*\(?['\"][^'\"]+['\"]\)?;" "$PROJ_PATH" 2>/dev/null | grep -v "vendor" | sort | uniq -c | sort -nr | head -n 10 | awk '{print "  - Included " $1 " times: " $2" "$3}' >> "$OUT_FILE"

# --- [4] API & ENDPOINTS DETECTOR ---
echo -e "\n[4] DETECTED API & AJAX ENDPOINTS" >> "$OUT_FILE"
echo "-----------------------------------" >> "$OUT_FILE"
sudo find "$PROJ_PATH" -type f \( -name "*api*.php" -o -name "*ajax*.php" -o -name "*handler*.php" \) -exec basename {} \; | sort | uniq | sed 's/^/  - /' >> "$OUT_FILE"

# --- [5] DATABASE SCHEMA DUMP ---
echo -e "\n[5] DATABASE SCHEMA ($DB_NAME)" >> "$OUT_FILE"
echo "-----------------------------------" >> "$OUT_FILE"
if [ -n "$DB_NAME" ]; then
    DB_EXISTS=$(sudo mysql -N -e "SHOW DATABASES LIKE '$DB_NAME';")
    if [ -n "$DB_EXISTS" ]; then
        sudo mysql -N -e "SELECT TABLE_NAME, COLUMN_NAME, DATA_TYPE FROM information_schema.COLUMNS WHERE TABLE_SCHEMA = '$DB_NAME' ORDER BY TABLE_NAME;" | awk '{
            if ($1 != prev) {
                print "\nTable: " $1;
                prev=$1;
            }
            print "  - " $2 " (" $3 ")";
        }' >> "$OUT_FILE"
    else
        echo "❌ Database '$DB_NAME' does not exist in MySQL." >> "$OUT_FILE"
    fi
else
    echo "❌ No Database configured." >> "$OUT_FILE"
fi

# --- [6] FULL PROJECT TREE ---
echo -e "\n\n[6] PROJECT FILE STRUCTURE (PHP, JS, CSS, ENV)" >> "$OUT_FILE"
echo "-----------------------------------" >> "$OUT_FILE"
cd "$PROJ_PATH" || exit
# Exclude heavy folders, show tree of core files
sudo find . -type d \( -name "vendor" -o -name "node_modules" -o -name ".git" -o -name "uploads" \) -prune -o -type f \( -name "*.php" -o -name "*.js" -o -name "*.css" -o -name "*.env" -o -name "*.json" \) -print | sed -e 's;[^/]*/;|____;g;s;____|; |;g' >> "$OUT_FILE"
echo "=====================================================" >> "$OUT_FILE"

# 5. Display the output cleanly
clear
echo -e "${GREEN}✅ ULTIMATE CONTEXT GENERATED SUCCESSFULLY!${RESET}"
echo -e "${YELLOW}👇 Copy the FULL text below and paste it to ChatGPT/Gemini:${RESET}"
echo -e "${CYAN}-------------------------------------------------------------------------${RESET}"
cat "$OUT_FILE"
echo -e "${CYAN}-------------------------------------------------------------------------${RESET}"
