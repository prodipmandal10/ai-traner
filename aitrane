#!/bin/bash

# --- 🪄 MAGIC DOS2UNIX AUTO-FIX ---
if grep -q $'\r' "$0"; then
    echo -e "\e[33m[*] Fixing Line Endings automatically...\e[0m"
    sed -i 's/\r$//' "$0"
    exec bash "$0" "$@"
fi
# ----------------------------------------------------

# Colors
GREEN="\e[32m"
CYAN="\e[36m"
YELLOW="\e[33m"
MAGENTA="\e[35m"
RED="\e[31m"
RESET="\e[0m"

BASE_DIR="/var/www/html"
OUT_FILE="/tmp/ai_context_dump.txt"

clear
echo -e "${MAGENTA}=====================================================${RESET}"
echo -e "${GREEN} 👁️‍🗨️ AI CONTEXT SPY - GOD MODE (V3.0) 👁️‍🗨️ ${RESET}"
echo -e "${MAGENTA}=====================================================${RESET}"

# 1. Get Project List
cd "$BASE_DIR" || exit
shopt -s nullglob
DIRS=(*/)
shopt -u nullglob

if [ ${#DIRS[@]} -eq 0 ]; then 
    echo -e "${RED}[-] No projects found!${RESET}"
    exit 1
fi

PROJ_LIST=()
echo -e "${YELLOW}Available Projects:${RESET}"
echo -e "${BLUE}-----------------------------------------------------${RESET}"
for i in "${!DIRS[@]}"; do
    PROJ_NAME="${DIRS[$i]%/}"
    if [[ "$PROJ_NAME" != *"_baseline_safe"* && "$PROJ_NAME" != "phpmyadmin" ]]; then
        PROJ_LIST+=("$PROJ_NAME")
        echo -e "${GREEN}  $(( ${#PROJ_LIST[@]} ))) 📁 $PROJ_NAME${RESET}"
    fi
done
echo -e "${BLUE}-----------------------------------------------------${RESET}"
echo -e "${RED}  0) ❌ Exit${RESET}"

# 2. Select Project
read -p "Select a Project SL No [0-${#PROJ_LIST[@]}]: " CH
CH=$(echo "$CH" | tr -cd '0-9')

if [[ "$CH" == "0" || -z "$CH" || "$CH" -gt "${#PROJ_LIST[@]}" ]]; then exit 0; fi

SELECTED_PROJ="${PROJ_LIST[$((CH-1))]}"
PROJ_PATH="$BASE_DIR/$SELECTED_PROJ"

# 3. Database Selection (Interactive for 100% accuracy)
echo -e "\n${CYAN}[*] Scanning for Database Name...${RESET}"
DETECTED_DB=$(sudo grep -rhiEo "(DB_NAME|dbname|database|db_database)[\"'\s=>]+[\"'][^\"']+[\"']" "$PROJ_PATH" | grep -v "\$" | head -n 1 | grep -oP "['\"][^'\"]+['\"]" | tr -d "'\"")
if [ -z "$DETECTED_DB" ]; then
    DETECTED_DB=$(sudo grep -rhiP 'new\s+mysqli\s*\(' "$PROJ_PATH" | head -n 1 | awk -F',' '{print $4}' | tr -d " '\"()")
fi

echo -e "${YELLOW}Detected DB: ${CYAN}${DETECTED_DB:-None}${RESET}"
read -p "Press Enter to use this DB, OR type the exact Database Name manually: " USER_DB
DB_NAME=${USER_DB:-$DETECTED_DB}

echo -e "\n${YELLOW}[*] Extracting God-Mode Context for: ${CYAN}$SELECTED_PROJ${RESET}..."

# 4. Generate Context Report
> "$OUT_FILE"

echo "Hello AI, I am building/editing a PHP & MySQL project. Below is the complete server architecture, file structure, and database schema. Keep this context in mind for all future code generation." >> "$OUT_FILE"
echo "" >> "$OUT_FILE"
echo "=====================================================" >> "$OUT_FILE"
echo " 📁 PROJECT PROFILE: $SELECTED_PROJ " >> "$OUT_FILE"
echo "=====================================================" >> "$OUT_FILE"

# --- SYSTEM & NGINX ---
CONF_FILE=$(sudo grep -rl "root $PROJ_PATH" /etc/nginx/sites-available/ /etc/nginx/sites-enabled/ 2>/dev/null | head -n 1)
DOMAIN=$(sudo awk '/server_name/ {print $0}' "$CONF_FILE" 2>/dev/null | head -n 1 | sed 's/server_name //;s/;//;s/^[ \t]*//')
EXT_LESS=$(sudo grep -q "@php" "$CONF_FILE" 2>/dev/null && echo "YES" || echo "NO")

echo -e "\n[1] ENVIRONMENT & SERVER" >> "$OUT_FILE"
echo "-----------------------------------" >> "$OUT_FILE"
echo "Project Dir : $PROJ_PATH" >> "$OUT_FILE"
echo "PHP Version : $(php -v | head -n 1 | cut -d' ' -f1,2)" >> "$OUT_FILE"
echo "Domain Used : ${DOMAIN:-Localhost}" >> "$OUT_FILE"
echo "Clean URLs  : $EXT_LESS (Extensionless .php)" >> "$OUT_FILE"

# --- DATABASE SCHEMA DUMP ---
echo -e "\n[2] DATABASE SCHEMA ($DB_NAME)" >> "$OUT_FILE"
echo "-----------------------------------" >> "$OUT_FILE"
if [ -n "$DB_NAME" ]; then
    DB_EXISTS=$(sudo mysql -N -e "SHOW DATABASES LIKE '$DB_NAME';")
    if [ -n "$DB_EXISTS" ]; then
        sudo mysql -N -e "SELECT TABLE_NAME, COLUMN_NAME, DATA_TYPE FROM information_schema.COLUMNS WHERE TABLE_SCHEMA = '$DB_NAME' ORDER BY TABLE_NAME;" | awk '{
            if ($1 != prev) {
                print "\nTable: " $1;
                prev=$1;
            }
            print "  - " $2 " (" $3 ")";
        }' >> "$OUT_FILE"
    else
        echo "❌ Database '$DB_NAME' does not exist in MySQL." >> "$OUT_FILE"
    fi
else
    echo "❌ No Database configured." >> "$OUT_FILE"
fi

# --- PROJECT FILE STRUCTURE ---
echo -e "\n\n[3] PROJECT FILE STRUCTURE (PHP Files)" >> "$OUT_FILE"
echo "-----------------------------------" >> "$OUT_FILE"
cd "$PROJ_PATH" || exit
# Exclude vendor and node_modules, show tree structure of PHP files
sudo find . -type d \( -name "vendor" -o -name "node_modules" \) -prune -o -type f -name "*.php" -print | sed -e 's;[^/]*/;|____;g;s;____|; |;g' >> "$OUT_FILE"
echo "=====================================================" >> "$OUT_FILE"

# 5. Display the output cleanly
clear
echo -e "${GREEN}✅ GOD-MODE CONTEXT GENERATED SUCCESSFULLY!${RESET}"
echo -e "${YELLOW}👇 Copy the FULL text below and paste it to ChatGPT/Gemini:${RESET}"
echo -e "${CYAN}-------------------------------------------------------------------------${RESET}"
cat "$OUT_FILE"
echo -e "${CYAN}-------------------------------------------------------------------------${RESET}"
